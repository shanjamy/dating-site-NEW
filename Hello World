const Avatar = ({ seed, size = 48, blur, verified, active }) => {
  const colors = [
    ["#7C3AED", "#EC4899"],
    ["#0891B2", "#8B5CF6"],
    ["#D97706", "#EF4444"],
    ["#059669", "#0891B2"],
    ["#DB2777", "#7C3AED"],
  ];
  const [c1, c2] = colors[seed % colors.length];
  const initials = ["AR", "SK", "PM", "NR", "VK", "AS", "RD", "MG"][seed % 8];
  return (
    <div style={{ position: "relative", display: "inline-flex", flexShrink: 0 }}>
      <div
        style={{
          width: size,
          height: size,
          borderRadius: "50%",
          background: `linear-gradient(135deg, ${c1}, ${c2})`,
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          fontSize: size * 0.3,
          fontWeight: 700,
          color: "#fff",
          filter: blur ? "blur(8px)" : "none",
          fontFamily: "'Syne', sans-serif",
          flexShrink: 0,
        }}
      >
        {!blur && initials}
      </div>
      {active && (
        <div
          style={{
            position: "absolute",
            bottom: 2,
            right: 2,
            width: size * 0.22,
            height: size * 0.22,
            borderRadius: "50%",
            background: T.green,
            border: `2px solid ${T.bg}`,
          }}
        />
      )}
      {verified && (
        <div
          style={{
            position: "absolute",
            bottom: -2,
            right: -2,
            width: 18,
            height: 18,
            borderRadius: "50%",
            background: T.neon,
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            fontSize: 9,
            border: `2px solid ${T.bg}`,
          }}
        >
          ✓
        </div>
      )}
    </div>
  );
};

