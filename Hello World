// ─── MAIN APP ─────────────────────────────────────────────────────────────────
export default function App() {
  const [screen, setScreen] = useState("splash");
  const [tab, setTab] = useState("discover");
  const [openChat, setOpenChat] = useState(null);
  const showTabs = screen === "main";

  const onboardingFlow = [
    "splash", "welcome", "otp", "faceVerify", "basicInfo", "privacy", "location", "main"
  ];

  const goNext = () => {
    const cur = onboardingFlow.indexOf(screen);
    if (cur < onboardingFlow.length - 1) setScreen(onboardingFlow[cur + 1]);
  };

  const renderScreen = () => {
    if (screen === "splash") return <SplashScreen onDone={goNext} />;
    if (screen === "welcome") return <WelcomeScreen onSignup={goNext} onLogin={goNext} />;
    if (screen === "otp") return <OTPScreen onNext={goNext} />;
    if (screen === "faceVerify") return <FaceVerifyScreen onNext={goNext} />;
    if (screen === "basicInfo") return <BasicInfoScreen onNext={goNext} />;
    if (screen === "privacy") return <PrivacyScreen onNext={goNext} />;
    if (screen === "location") return <LocationScreen onNext={goNext} />;

    if (screen === "main") {
      if (openChat)
        return <ChatDetailScreen chat={openChat} onBack={() => setOpenChat(null)} />;
      if (tab === "discover") return <DiscoverScreen />;
      if (tab === "requests") return <RequestsScreen />;
      if (tab === "chat") return <ChatListScreen onOpen={(c) => setOpenChat(c)} />;
      if (tab === "profile") return <ProfileScreen />;
    }
  };

  return (
    <>
      <style>{globalCSS}</style>
      <div
        style={{
          width: "100%",
          height: "100vh",
          background: T.bg,
          display: "flex",
          justifyContent: "center",
          alignItems: "center",
        }}
      >
        <div
          style={{
            width: 390,
            height: 844,
            background: T.bg,
            borderRadius: 44,
            overflow: "hidden",
            position: "relative",
            boxShadow: `0 0 0 1px ${T.border}, 0 40px 120px rgba(0,0,0,0.8), 0 0 60px ${T.neonSoft}`,
          }}
        >
          {/* Status bar */}
          <div
            style={{
              position: "absolute",
              top: 0,
              left: 0,
              right: 0,
              height: 44,
              zIndex: 200,
              display: "flex",
              justifyContent: "space-between",
              alignItems: "center",
              padding: "0 24px",
              pointerEvents: "none",
            }}
          >
            <span style={{ fontSize: 12, fontWeight: 600 }}>9:41</span>
            <div style={{ display: "flex", gap: 6, alignItems: "center" }}>
              <span style={{ fontSize: 11 }}>▬▬▬</span>
              <span style={{ fontSize: 11 }}>🛜</span>
              <span style={{ fontSize: 11 }}>🔋</span>
            </div>
          </div>

          {/* Screens */}
          <div style={{ position: "absolute", inset: 0 }}>{renderScreen()}</div>

          {/* Tab bar */}
          {showTabs && !openChat && <TabBar tab={tab} setTab={setTab} />}

          {/* Onboarding nav hint */}
          {screen !== "splash" && screen !== "main" && (
            <div
              style={{
                position: "absolute",
                top: 52,
                left: 24,
                zIndex: 300,
              }}
            >
              <button
                className="btn-press"
                onClick={() => {
                  const cur = onboardingFlow.indexOf(screen);
                  if (cur > 1) setScreen(onboardingFlow[cur - 1]);
                }}
                style={{
                  background: T.bgGlass,
                  border: `1px solid ${T.border}`,
                  borderRadius: 12,
                  color: T.textMuted,
                  fontSize: 16,
                  cursor: "pointer",
                  padding: "6px 12px",
                }}
              >
                ←
              </button>
            </div>
          )}
        </div>
      </div>
    </>
  );
}
