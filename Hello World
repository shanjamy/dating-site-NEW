        </div>

        {/* Progress bar */}
        {step === "scanning" && (
          <div style={{ marginBottom: 24 }}>
            <div style={{ height: 4, borderRadius: 4, background: T.bgGlass, overflow: "hidden", marginBottom: 8 }}>
