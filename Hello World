// OTP SCREEN
const OTPScreen = ({ onNext }) => {
  const [phone, setPhone] = useState("");
  const [step, setStep] = useState("phone"); // phone | otp
  const [otp, setOtp] = useState(["", "", "", "", "", ""]);
  const [sending, setSending] = useState(false);
  const refs = useRef([]);

  const sendOTP = () => {
    setSending(true);
    setTimeout(() => {
      setSending(false);
      setStep("otp");
    }, 1200);
  };

  const handleOtp = (val, idx) => {
    const d = [...otp];
    d[idx] = val.slice(-1);
    setOtp(d);
    if (val && idx < 5) refs.current[idx + 1]?.focus();
    if (d.every((v) => v) && idx === 5) setTimeout(onNext, 400);
  };

  return (
    <div style={{ position: "absolute", inset: 0, background: T.bg, padding: "60px 28px 40px", display: "flex", flexDirection: "column" }}>
      <div className="anim-fade-up">
        <div style={{ fontSize: 28, fontFamily: "'Syne', sans-serif", fontWeight: 700, marginBottom: 8 }}>
          {step === "phone" ? "Your number 📱" : "Verify OTP 🔐"}
        </div>
        <div style={{ color: T.textMuted, fontSize: 14, marginBottom: 32 }}>
          {step === "phone"
            ? "We'll send a one-time code to verify your identity"
            : `Code sent to +91 ${phone}`}
        </div>

        {step === "phone" ? (
          <>
            <GlassCard style={{ padding: "4px 16px", display: "flex", alignItems: "center", gap: 12, marginBottom: 20 }}>
              <span style={{ color: T.textMuted, fontSize: 14, whiteSpace: "nowrap" }}>🇮🇳 +91</span>
              <div style={{ width: 1, height: 24, background: T.border }} />
              <input
                type="tel"
                placeholder="Enter mobile number"
                value={phone}
                onChange={(e) => setPhone(e.target.value)}
                style={{ flex: 1, fontSize: 16, padding: "14px 0" }}
                maxLength={10}
              />
            </GlassCard>
            <NeonButton onClick={sendOTP} disabled={phone.length < 10 || sending}>
              {sending ? "Sending..." : "Send OTP"}
            </NeonButton>
          </>
        ) : (
          <>
            <div style={{ display: "flex", gap: 10, marginBottom: 28 }}>
              {otp.map((v, i) => (
                <input
                  key={i}
                  ref={(r) => (refs.current[i] = r)}
                  type="text"
                  inputMode="numeric"
                  maxLength={1}
                  value={v}
                  onChange={(e) => handleOtp(e.target.value, i)}
                  style={{
                    flex: 1,
                    height: 56,
                    textAlign: "center",
                    fontSize: 22,
                    fontWeight: 700,
                    borderRadius: 14,
                    background: v ? T.neonSoft : T.bgGlass,
                    border: `1px solid ${v ? T.neon : T.border}`,
                    color: T.text,
                    boxShadow: v ? `0 0 12px ${T.neonSoft}` : "none",
                    transition: "all 0.2s ease",
                  }}
                />
              ))}
            </div>
            <div style={{ textAlign: "center", color: T.textMuted, fontSize: 13, marginBottom: 24 }}>
              Didn't receive?{" "}
              <span style={{ color: T.neon, fontWeight: 600 }}>Resend in 30s</span>
            </div>
            <NeonButton onClick={onNext} disabled={!otp.every((v) => v)}>
              Verify & Continue
            </NeonButton>
          </>
        )}
      </div>

      {/* Trust indicators */}
      <div
        style={{
          marginTop: "auto",
          display: "flex",
          alignItems: "center",
          gap: 8,
          padding: "14px 16px",
          borderRadius: 14,
          background: T.bgGlass,
          border: `1px solid ${T.border}`,
        }}
      >
        <span style={{ fontSize: 18 }}>🔒</span>
        <div>
          <div style={{ fontSize: 12, fontWeight: 600 }}>End-to-end encrypted</div>
          <div style={{ fontSize: 11, color: T.textMuted }}>Your data is protected under Indian IT Act</div>
        </div>
      </div>
    </div>
  );
};

// FACE VERIFICATION
const FaceVerifyScreen = ({ onNext }) => {
  const [step, setStep] = useState("intro"); // intro | scanning | done
  const [progress, setProgress] = useState(0);

  const startScan = () => {
    setStep("scanning");
    let p = 0;
    const iv = setInterval(() => {
      p += 2;
      setProgress(p);
      if (p >= 100) {
        clearInterval(iv);
        setStep("done");
      }
    }, 40);
  };

  return (
    <div style={{ position: "absolute", inset: 0, background: T.bg, padding: "60px 28px 48px", display: "flex", flexDirection: "column", alignItems: "center" }}>
      <div className="anim-fade-up" style={{ width: "100%", textAlign: "center" }}>
        <div style={{ fontSize: 28, fontFamily: "'Syne', sans-serif", fontWeight: 700, marginBottom: 8 }}>
          Face Verification 🤳
        </div>
        <div style={{ color: T.textMuted, fontSize: 14, marginBottom: 36 }}>
          Prove you're real. One-time verification keeps Aura fake-free.
        </div>

        {/* Camera frame */}
        <div style={{ position: "relative", width: 220, height: 280, margin: "0 auto 36px" }}>
          <div
            style={{
              position: "absolute",
              inset: 0,
              borderRadius: 28,
              background: step === "done" ? `${T.green}22` : step === "scanning" ? T.neonSoft : T.bgGlass,
              border: `2px solid ${step === "done" ? T.green : step === "scanning" ? T.neon : T.border}`,
              overflow: "hidden",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              transition: "all 0.4s ease",
              boxShadow: step === "scanning" ? `0 0 40px ${T.neonGlow}` : "none",
            }}
          >
            {step === "intro" && (
              <div style={{ fontSize: 64, opacity: 0.3 }}>👤</div>
            )}
            {step === "scanning" && (
              <div style={{ textAlign: "center" }}>
                <div style={{ fontSize: 48, marginBottom: 16 }}>🤳</div>
                <div style={{ fontSize: 12, color: T.neon }}>Analyzing...</div>
              </div>
            )}
            {step === "done" && (
              <div style={{ textAlign: "center" }}>
                <div style={{ fontSize: 48, marginBottom: 8 }}>✅</div>
                <div style={{ fontSize: 13, color: T.green, fontWeight: 600 }}>Verified!</div>
              </div>
            )}

            {/* Scanning line */}
            {step === "scanning" && (
              <div
                style={{
                  position: "absolute",
                  left: 0,
                  right: 0,
                  height: 2,
